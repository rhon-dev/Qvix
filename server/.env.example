# Postgres connection string. Leave unset to run without persistence
# (the game still works; only the Hall of Fame leaderboard is disabled).
DATABASE_URL=postgres://user:password@localhost:5432/knowdown

# Port the HTTP + WebSocket server listens on. Railway/Heroku set this for you.
PORT=4000

# Comma-separated list of allowed CORS origins. Use * for local dev,
# lock it down to your Vercel domain in production.
CORS_ORIGIN=*

# --- Optional gameplay / safety tuning (sensible defaults shown) ---
# Number of questions per game (clamped to the question bank size).
QUESTION_COUNT=10
# Max players allowed in a single room.
MAX_PLAYERS_PER_ROOM=12
# Max concurrent rooms before new room creation is rejected.
MAX_ROOMS=1000
