{
  "name": "knowdown",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:client": "npm --workspace client run dev",
    "dev:server": "npm --workspace server run dev",
    "dev": "concurrently -n client,server -c blue,green \"npm:dev:client\" \"npm:dev:server\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
